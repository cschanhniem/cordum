{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cordum.io/schemas/edge/edge_session.schema.json",
  "title": "EdgeSession",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "tenant_id",
    "principal_id",
    "principal_type",
    "agent_product",
    "agent_version",
    "mode",
    "repo",
    "git_remote",
    "git_branch",
    "git_sha",
    "cwd",
    "host_id",
    "device_id",
    "trace_id",
    "workflow_run_id",
    "job_id",
    "policy_snapshot",
    "enforcement_layers",
    "policy_mode",
    "status",
    "risk_summary",
    "started_at",
    "ended_at",
    "labels"
  ],
  "properties": {
    "session_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "principal_id": { "type": "string" },
    "principal_type": { "type": "string", "enum": ["human", "service", "unknown"] },
    "agent_product": { "type": "string" },
    "agent_version": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["local-dev", "enterprise-managed", "workflow", "ci", "prod-runner"]
    },
    "repo": { "type": "string" },
    "git_remote": { "type": "string" },
    "git_branch": { "type": "string" },
    "git_sha": { "type": "string" },
    "cwd": { "type": "string" },
    "host_id": { "type": "string" },
    "device_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "workflow_run_id": { "type": ["string", "null"] },
    "job_id": { "type": ["string", "null"] },
    "policy_snapshot": { "type": "string" },
    "enforcement_layers": {
      "type": "object",
      "maxProperties": 16,
      "propertyNames": { "type": "string", "minLength": 1, "maxLength": 128 },
      "additionalProperties": { "type": "boolean" }
    },
    "policy_mode": { "type": "string", "enum": ["observe", "enforce", "enterprise-strict"] },
    "status": {
      "type": "string",
      "enum": ["starting", "running", "waiting_for_approval", "degraded", "ended", "failed"]
    },
    "risk_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["denied_count", "approval_count", "artifact_count", "max_risk"],
      "properties": {
        "denied_count": { "type": "integer", "minimum": 0 },
        "approval_count": { "type": "integer", "minimum": 0 },
        "artifact_count": { "type": "integer", "minimum": 0 },
        "max_risk": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
      }
    },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": ["string", "null"], "format": "date-time" },
    "labels": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": { "type": "string", "minLength": 1, "maxLength": 128 },
      "additionalProperties": { "type": "string", "maxLength": 512 }
    }
  }
}
