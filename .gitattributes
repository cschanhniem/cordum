# Ensure shell scripts always use LF line endings
*.sh text eol=lf

# Ensure batch files use CRLF (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# Proto files
*.proto text eol=lf

# Go source
*.go text eol=lf

# YAML/JSON config
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Dockerfile
Dockerfile text eol=lf

# Golden test fixtures: LF only (byte-compared vs json.MarshalIndent LF output). BUG-019
*.golden text eol=lf

# Markdown: LF only (gen_docs_tables marker regions must match committed LF; mixed EOL caused perpetual docs-tables-check drift). BUG-017
*.md text eol=lf
